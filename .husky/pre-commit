#!/usr/bin/env sh

BRANCH_NAME="$(git rev-parse --abbrev-ref HEAD)"
BRANCH_REGEX='^(feature|bugfix|hotfix|refactor|chore|docs|test|experiment|release)/[a-z0-9._-]+$'

if [ "$BRANCH_NAME" = "HEAD" ]; then
  echo "Skipping branch name validation in detached HEAD state."
elif ! echo "$BRANCH_NAME" | grep -Eq "$BRANCH_REGEX"; then
  echo "Invalid branch name: '$BRANCH_NAME'"
  echo "Expected format:"
  echo "  <type>/<description>"
  echo ""
  echo "Allowed types:"
  echo "  feature | bugfix | hotfix | refactor | chore | docs | test | experiment | release"
  echo ""
  echo "Examples:"
  echo "  feature/add-cart-summary"
  echo "  bugfix/fix-login-redirect"
  exit 1
fi

npm run precommit
