#!/usr/bin/env sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG="$(sed -n '1p' "$COMMIT_MSG_FILE")"
COMMIT_REGEX='^(feature|fixture|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+$'

if ! echo "$COMMIT_MSG" | grep -Eq "$COMMIT_REGEX"; then
  echo "Invalid commit message: '$COMMIT_MSG'"
  echo "Expected Conventional Commit format:"
  echo "  <type>(optional-scope): <description>"
  echo ""
  echo "Allowed types:"
  echo "  feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
  echo ""
  echo "Examples:"
  echo "  feat(auth): add login guard"
  echo "  fix: handle missing access token"
  echo "  refactor!: remove legacy API client"
  exit 1
fi
